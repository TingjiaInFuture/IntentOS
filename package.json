    "bcrypt": "^5.1.1",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/jsonwebtoken": "^9.0.5",
