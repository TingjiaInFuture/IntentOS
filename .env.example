# ===================================================================
# IntentOS - AI-Native Enterprise Management System
# ===================================================================

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
EMBEDDING_MODEL=text-embedding-3-small

# Database (system-owned persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/intentos

# Graph Database (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Vector Database
VECTOR_STORE_PROVIDER=pinecone
VECTOR_TOP_K=5
EMBEDDING_DIMENSION=1536
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=intentos-memory
PINECONE_NAMESPACE=intentos

# Optional vector backend: Milvus
# VECTOR_STORE_PROVIDER=milvus
# MILVUS_ADDRESS=localhost:19530
# MILVUS_COLLECTION=intentos_memory
# MILVUS_METRIC_TYPE=COSINE

# SMTP
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@intentos.local

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
