# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/intentos
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Vector Database (optional - for RAG)
VECTOR_STORE_PROVIDER=pinecone
VECTOR_TOP_K=5
EMBEDDING_DIMENSION=1536
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=intentos-memory
PINECONE_NAMESPACE=intentos
MILVUS_ADDRESS=localhost:19530
MILVUS_COLLECTION=intentos_memory
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_METRIC_TYPE=COSINE

# Enterprise Integrations
EMAIL_API_ENDPOINT=
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com
DOC_API_ENDPOINT=
DOC_API_KEY=
CALENDAR_API_ENDPOINT=
CALENDAR_API_KEY=
SLACK_BOT_TOKEN=
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_API_VERSION=v61.0
SAP_BASE_URL=https://your-sap-endpoint
SAP_USERNAME=
SAP_PASSWORD=
SAP_CLIENT=
SAP_API_KEY=
RPA_API_ENDPOINT=
RPA_API_KEY=

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
